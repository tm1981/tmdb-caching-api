# Choose once before setup: postgresql, mysql, or mariadb.
DATABASE_PROVIDER=postgresql

# PostgreSQL:
DATABASE_URL=postgresql://user:password@localhost:5432/tmdb_service

# MySQL or MariaDB:
# DATABASE_URL=mysql://user:password@localhost:3306/tmdb_service

TMDB_API_KEY=your_tmdb_api_key_here
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password
